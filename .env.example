# DashScope (Aliyun / Qwen) — get key at https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=sk-...

# Optional: override OpenAI-compatible base URL
#   default                : https://dashscope.aliyuncs.com/compatible-mode/v1
#   international DashScope: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   self-hosted vLLM       : http://your-h100-host:8000/v1
#   official OpenAI        : https://api.openai.com/v1
# OPENAI_BASE_URL=

# Default model. Common DashScope choices for Agent learning:
#   qwen-plus          balanced cost/quality, tool use stable (recommended default)
#   qwen-max           most capable, expensive
#   qwen-turbo         fastest, cheapest, may be weaker on multi-step tool use
#   qwen3-coder-plus   coding-focused
#   qwen3-max          latest top tier
LLM_MODEL=qwen-plus

# Langfuse (sign up at https://cloud.langfuse.com → create project → copy keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
